.back-to-top:focus {
  background: #1d4ed8 !important; /* brighter blue */
  box-shadow: 0 6px 20px rgba(29,78,216,0.4) !important;
}

/* Small screen center option */
@media (max-width: 420px) {
  .floating-apply {
    right: auto !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
  }
  .back-to-top {
    right: auto !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
  }
}



