/* Read More baseline alignment tweak */
.read-more, [id^="toggleBtn"] {
  display: inline-flex;
  align-items: baseline; /* align with text baseline */
  gap: 0.35rem;
  vertical-align: baseline;
  font-weight: 600;
  line-height: 1.1;
  padding: 0;
  background: transparent;
  border: none;
  cursor: pointer;
}

.read-more .label, [id^="toggleBtn"] .label {
  display: inline-block;
  vertical-align: baseline;
  line-height: 1.1;
  font-size: 0.95rem;
  color: inherit;
  margin: 0;
}

.read-more .icon, [id^="toggleBtn"] .icon {
  display: inline-block;
  vertical-align: baseline;
  transform: translateY(1px); /* nudge icon for pixel-perfect baseline alignment */
  font-size: 0.92rem;
  line-height: 1;
}
/* Small responsive tweak: reduce gap on small screens */
@media (max-width: 640px) {
  .read-more, [id^="toggleBtn"] { gap: 0.25rem; }
  .read-more .icon, [id^="toggleBtn"] .icon { transform: translateY(0.5px); }
}
