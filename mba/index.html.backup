<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<meta content="Admissions Open 2025 at Graphic Era University. Ranked 48 by NIRF 2025 with top placements and highest package ₹61.99 LPA at Atlassian. Explore our programs today." name="description"/>
<!-- Open Graph / Social Share -->
<meta content="Admissions Open 2025 | Graphic Era University" property="og:title"/>
<meta content="Ranked 48 by NIRF 2025 • Highest package ₹61.99 LPA • Apply Now!" property="og:description"/>
<meta content="../assets/img/main/bg-image.webp" property="og:image"/>
<meta content="website" property="og:type"/>
<!-- Page Title -->
<title>Admissions Open 2025 | Graphic Era University</title>
<!-- Tailwind & jQuery -->
<script src="https://cdn.tailwindcss.com"></script>
<link href="/assets/img/main/favicon.svg" rel="icon" sizes="any"/>
<link href="/assets/img/main/favicon.svg" rel="icon" type="image/svg+xml"/>
<!-- Swiper -->
<link href="../assets/css/swiper-bundle.min.css" rel="stylesheet"/>
<link href="../assets/css/styles.css" rel="stylesheet"/>
<!-- Preload the hero image with responsive candidates -->
<link as="image" href="../assets/img/main/bg-image-480.webp" media="(max-width: 767px)" rel="preload" type="image/webp">
<link as="image" href="../assets/img/main/bg-image-768.webp" media="(min-width: 768px) and (max-width: 1279px)" rel="preload" type="image/webp">
<link as="image" href="../assets/img/main/bg-image-1280.webp" media="(min-width: 1280px) and (max-width: 1919px)" rel="preload" type="image/webp"/>
<link as="image" href="../assets/img/main/bg-image-1920.webp" media="(min-width: 1920px)" rel="preload" type="image/webp"/>
<script>
  window.addEventListener("load", () => {
    const el = document.querySelector(".hero-bg");
    if (el) el.classList.add("loaded");
  });
</script>
<link href="assets/css/layout-fixes.css" rel="stylesheet"/>
</link></link></head>
<body class="font-sans text-gray-900 bg-white">
<!-- Logo Bar -->
<div class="sticky top-0 z-50 flex items-center justify-center py-3 shadow-md bg-blue-900">
<img alt="Graphic Era Logo" class="h-12" src="../assets/img/main/logo.svg"/>
</div>
<!-- Hero Section -->
<header class="relative text-white overflow-hidden" style="background: radial-gradient(circle at center, #1e3a8a 0%, #1e40af 40%, #111827 100%);">
<div class="absolute inset-0 hero-bg opacity-40"></div>
<div class="relative z-10 grid md:grid-cols-2 gap-8 items-center min-h-[80vh] px-4 sm:px-6">
<!-- Hero Text -->
<!-- Hero Text -->
<!-- Hero Text -->
<div class="text-center md:text-left md:pl-40 pt-8 md:pt-0">
<h1 class="text-3xl sm:text-4xl md:text-6xl font-extrabold mb-4 text-white">
    Admissions Open 2025
  </h1>
<p class="text-base sm:text-lg md:text-xl mb-6 text-white">
    Begin your Career at the university ranked 
    <span class="font-bold underline decoration-amber-400 decoration-2">
      52 amongst top universities of India by NIRF 2025
    </span> 
    with consistently high placements and highest package of 
    <span class="font-bold underline decoration-amber-400 decoration-2">
      ₹61.99 Lacs at Atlassian
    </span>.
  </p>
<div class="grid grid-cols-2 gap-3 max-w-sm mx-auto md:mx-0">
<!-- Highest Placement -->
<div class="flex flex-col items-center bg-white rounded-xl p-4 shadow-md relative">
<div class="absolute inset-0 rounded-xl border-2 border-dashed border-amber-500 pointer-events-none" style="border-spacing: 6px; box-shadow: inset 0 0 0 2px white;"></div>
<svg class="h-7 w-7 text-amber-600 mb-2 relative z-10" fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M7 2v2H4a1 1 0 0 0-1 1v2c0 2.21 1.79 4 4 4h.08A6.002 6.002 0 0 0 11 17.92V20H9a1 1 0 0 0-1 1v1h8v-1a1 1 0 0 0-1-1h-2v-2.08A6.002 6.002 0 0 0 15.92 11H16c2.21 0 4-1.79 4-4V5a1 1 0 0 0-1-1h-3V2H7zm-3 4h3v2a4.002 4.002 0 0 1-3-2zm16 0a4.002 4.002 0 0 1-3 2V6h3z"></path>
</svg>
<p class="text-lg font-extrabold text-blue-900 relative z-10">₹61.99 Lacs</p>
<p class="text-xs text-gray-700 text-center relative z-10">
        Highest Placement<br/>
<span class="font-bold underline decoration-amber-500 decoration-2">At Atlassian</span>
</p>
</div>
<!-- NIRF Ranking -->
<div class="flex flex-col items-center bg-white rounded-xl p-4 shadow-md relative">
<div class="absolute inset-0 rounded-xl border-2 border-dashed border-blue-600 pointer-events-none" style="border-spacing: 6px; box-shadow: inset 0 0 0 2px white;"></div>
<svg class="h-7 w-7 text-blue-700 mb-2 relative z-10" fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 2a7 7 0 0 0-7 7c0 2.61 1.27 4.9 3.22 6.3L6 22l6-3 6 3-2.22-6.7A7 7 0 0 0 19 9a7 7 0 0 0-7-7z"></path>
</svg>
<p class="text-lg font-extrabold text-blue-900 relative z-10">Ranked 48</p>
<p class="text-xs text-gray-700 text-center relative z-10">
        Amongst Top Universities<br/>
<span class="font-bold underline decoration-blue-600 decoration-2">NIRF 2025</span>
</p>
</div>
</div>
</div>
<!-- Form -->
<div class="bg-white/95 text-gray-900 rounded-lg shadow-lg p-4 w-full max-w-xs mx-auto border border-gray-200 mb-8 md:mb-0" id="formContainer">
<h2 class="text-base font-bold text-center text-blue-800 mb-3">Apply Now</h2>
<form class="flex flex-col gap-2 text-xs" id="admissionForm" novalidate="">
<!-- Name -->
<div>
<label class="block text-[11px] font-semibold text-gray-700 mb-0.5" for="name">Full Name</label>
<input class="rounded border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-2 py-1.5 w-full text-xs transition" id="name" name="name" placeholder="Your Name" required="" type="text"/>
<small class="text-red-500 hidden text-[11px]" id="error-name">Enter valid name (min 3 letters, alphabets only).</small>
</div>
<!-- Email -->
<div>
<label class="block text-[11px] font-semibold text-gray-700 mb-0.5" for="email">Email</label>
<input class="rounded border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-2 py-1.5 w-full text-xs transition" id="email" name="email" placeholder="Your Email" required="" type="email"/>
<small class="text-red-500 hidden text-[11px]" id="error-email">Enter valid email.</small>
</div>
<!-- Phone -->
<div>
<label class="block text-[11px] font-semibold text-gray-700 mb-0.5" for="phone">Phone Number</label>
<input class="rounded border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-2 py-1.5 w-full text-xs transition" id="phone" maxlength="10" name="phone" placeholder="10-digit Number" required="" type="tel"/>
<small class="text-red-500 hidden text-[11px]" id="error-phone">Enter valid 10-digit phone.</small>
</div>
<!-- State -->
<div>
<label class="block text-[11px] font-semibold text-gray-700 mb-0.5" for="state">State</label>
<select class="rounded border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-2 py-1.5 w-full text-xs transition" id="state" name="state"></select>
</div>
<!-- City -->
<div>
<label class="block text-[11px] font-semibold text-gray-700 mb-0.5" for="city">City</label>
<select class="rounded border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-2 py-1.5 w-full text-xs transition" disabled="" id="city" name="city"></select>
</div>
<!-- Department -->
<div>
<label class="block text-[11px] font-semibold text-gray-700 mb-0.5" for="department">Department</label>
<select class="rounded border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-2 py-1.5 w-full text-xs transition" id="department" name="department"></select>
</div>
<!-- Course -->
<div>
<label class="block text-[11px] font-semibold text-gray-700 mb-0.5" for="course">Course</label>
<select class="rounded border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-2 py-1.5 w-full text-xs transition" disabled="" id="course" name="course"></select>
</div>
<!-- Consent -->
<div>
<label class="flex items-start gap-1 text-[11px] bg-gray-50 p-2 rounded border border-gray-200 leading-tight" for="consent">
<input class="mt-0.5 h-3.5 w-3.5 text-blue-600 rounded focus:ring-blue-500" id="consent" name="consent" required="" type="checkbox"/>
        I authorize Graphic Era to contact me via Email, SMS, WhatsApp and Call. This will override DND / NDNC.
      </label>
<small class="text-red-500 hidden text-[11px]" id="error-consent">You must agree before submitting.</small>
</div>
<!-- Submit -->
<button class="bg-gradient-to-r from-blue-600 to-yellow-400 hover:from-blue-700 hover:to-yellow-500 text-white rounded py-1.5 font-semibold shadow-md text-sm transition transform hover:scale-[1.02]" type="submit">
      Submit
    </button>
</form>
<!-- Thank You -->
<div class="hidden text-center mt-4" id="thankYou">
<p class="text-green-700 font-semibold text-sm">Thank you, one of our counselor will be in touch with you.</p>
<div class="w-full bg-gray-200 h-1.5 rounded-full mt-2 overflow-hidden">
<div class="h-1.5 rounded-full animate-progress" id="progressBar"></div>
</div>
<span class="text-[11px] block mt-1 text-green-600" id="countdown"></span>
</div>
</div>
<!-- form end-->
</div>
</header>
<!-- Courses Offered -->
<section class="section-spacing-sm px-6 bg-gray-50">
<!-- Heading -->
<h2 class="text-4xl md:text-5xl font-extrabold text-center mb-12 bg-gradient-to-r from-blue-700 via-blue-600 to-yellow-500 bg-clip-text text-transparent">
    Explore Our Programs
  </h2>
<!-- Filters inside card -->
<div class="bg-white rounded-2xl shadow-md p-6 mb-12 max-w-6xl mx-auto">
<div class="flex flex-col lg:flex-row lg:items-end gap-4">
<!-- Search -->
<div class="relative flex-1 min-w-[220px]">
<!-- Search Icon -->
<svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1110.5 3a7.5 7.5 0 016.15 13.65z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
<!-- Input -->
<input class="peer block w-full appearance-none rounded-lg border border-gray-300 bg-white pl-10 pr-3 pt-5 pb-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none" id="courseSearch" name="courseSearch" placeholder=" "/>
<!-- Floating Label -->
<label class="absolute left-10 top-2 text-gray-700 text-xs bg-white px-1 transition-all peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-gray-500 peer-placeholder-shown:text-sm peer-focus:top-1 peer-focus:text-xs peer-focus:text-blue-600" for="courseSearch">
  Search Courses
</label>
</div>
<!-- Level -->
<div class="relative flex-1 lg:flex-none lg:w-1/4">
<select class="peer block w-full appearance-none rounded-lg border border-gray-300 bg-white px-3 pt-5 pb-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none [&amp;&gt;option]:text-gray-700 [&amp;&gt;option]:py-2" id="levelFilter" name="levelFilter">
<option disabled="" hidden="" selected="" value=""></option>
<option value="UG">Undergraduate</option>
<option value="PG">Postgraduate</option>
</select>
<label class="absolute left-3 top-2 text-gray-500 text-xs bg-white px-1 transition-all peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm peer-focus:top-1 peer-focus:text-xs peer-focus:text-blue-600" for="levelFilter">
          Select Level
        </label>
<!-- Chevron Icon -->
<svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<!-- Department (dynamic options injected by JS) -->
<div class="relative flex-1 lg:flex-none lg:w-1/4">
<select class="peer block w-full appearance-none rounded-lg border border-gray-300 bg-white px-3 pt-5 pb-2 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 focus:outline-none [&amp;&gt;option]:text-gray-700 [&amp;&gt;option]:py-2" id="deptFilter" name="deptFilter">
<option disabled="" hidden="" selected="" value=""></option>
<!-- JS will inject department options here -->
</select>
<label class="absolute left-3 top-2 text-gray-500 text-xs bg-white px-1 transition-all peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-gray-400 peer-placeholder-shown:text-sm peer-focus:top-1 peer-focus:text-xs peer-focus:text-blue-600" for="deptFilter">
          Select Department
        </label>
<!-- Chevron Icon -->
<svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
</svg>
</div>
<!-- Clear Button -->
<div class="flex items-stretch">
<button class="h-[48px] flex items-center justify-center rounded-lg px-6 text-sm font-semibold text-white bg-gradient-to-r from-blue-600 to-yellow-400 hover:from-blue-700 hover:to-yellow-500 active:from-blue-800 active:to-yellow-600 shadow-md transition transform hover:scale-105" id="clearFilters">
          Clear
        </button>
</div>
</div>
</div>
<!-- Course Slider -->
<div class="swiper mySwiper max-w-6xl mx-auto pb-16">
<div class="swiper-wrapper" id="courseSlider">
<!-- JS injects course cards here -->
</div>
<!-- Progress Bar -->
</div>
<!-- No Results -->
<p class="hidden text-center text-gray-600 mt-10 text-lg font-medium" id="noResults">
    ❌ No courses found. Try adjusting your filters.
  </p>
</section>
<!-- Scholarship Highlights Start-->
<section class="section-spacing px-6 bg-gradient-to-r from-blue-50 via-white to-yellow-50">
<div class="max-w-7xl mx-auto">
<!-- Heading -->
<h2 class="text-4xl md:text-5xl font-extrabold text-center text-blue-900 mb-16">
      Scholarship <span class="text-yellow-500">Highlights</span>
</h2>
<div class="grid gap-10 md:grid-cols-3">
<!-- Card 1 -->
<div class="bg-white rounded-2xl shadow-xl p-10 text-center transform hover:-translate-y-3 transition duration-300 relative overflow-hidden">
<!-- Gradient Bar (kept same for visual) -->
<div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-yellow-500 to-yellow-600"></div>
<!-- Fixed contrast (darker yellow for text) -->
<div class="text-5xl font-extrabold text-yellow-800 mb-4">70%</div>
<p class="text-lg font-semibold">Merit Based Scholarships</p>
<p class="text-gray-700 mt-2">Awarded to high-performing students across programs.</p>
</div>
<!-- Card 2 -->
<div class="bg-white rounded-2xl shadow-xl p-10 text-center transform hover:-translate-y-3 transition duration-300 relative overflow-hidden">
<div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-blue-500 to-blue-600"></div>
<div class="text-5xl font-extrabold text-blue-600 mb-4">10%</div>
<p class="text-lg font-semibold">For Female Candidates</p>
<p class="text-gray-600 mt-2">Additional support to empower women in higher education.</p>
</div>
<!-- Card 3 -->
<div class="bg-white rounded-2xl shadow-xl p-10 text-center transform hover:-translate-y-3 transition duration-300 relative overflow-hidden">
<div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-blue-400 to-yellow-500"></div>
<div class="text-5xl font-extrabold text-blue-700 mb-4">5%</div>
<p class="text-lg font-semibold">Wards of Defence Personnel</p>
<p class="text-gray-600 mt-2">Tuition fee waiver as a token of gratitude for service.</p>
</div>
</div>
</div>
</section>
<!-- Scholarship Highlights STOP -->
<!-- Admission Process -->
<!-- Admission Process -->
<section class="section-spacing px-6 bg-gradient-to-r from-yellow-50 via-white to-gray-50 overflow-hidden">
<div class="relative max-w-6xl mx-auto">
<!-- Gradient Heading -->
<h2 class="text-4xl font-extrabold text-center mb-20 bg-gradient-to-r from-blue-800 via-blue-600 to-yellow-500 bg-clip-text text-transparent animate-gradient">
      Admission Process
    </h2>
<div class="relative">
<!-- Timeline line -->
<div class="hidden md:block absolute top-1/2 left-0 right-0 h-1 bg-gradient-to-r from-yellow-400 via-blue-500 to-yellow-400 animate-pulse -z-10"></div>
<!-- Steps -->
<div class="flex flex-col md:flex-row items-stretch justify-between gap-10 md:gap-6 relative z-10">
<!-- Step 1 -->
<div class="group bg-white rounded-xl shadow-lg p-8 text-center flex-1 opacity-0 translate-y-6 transition-all duration-700 ease-out hover:shadow-2xl hover:-translate-y-2" data-animate="">
<div class="w-16 h-16 mx-auto bg-yellow-400 text-blue-900 rounded-full flex items-center justify-center font-bold shadow-md text-xl transition transform group-hover:scale-125 group-hover:rotate-6 animate-bounce-slow">1</div>
<h3 class="mt-6 text-lg font-bold text-blue-700 group-hover:text-yellow-500 transition relative inline-block after:block after:h-0.5 after:bg-yellow-400 after:scale-x-0 group-hover:after:scale-x-100 after:transition after:origin-left">
            Application Form
          </h3>
<p class="text-gray-600 text-sm mt-3 animate-fade-in">Apply online with personal &amp; academic details.</p>
</div>
<!-- Step 2 -->
<div class="group bg-white rounded-xl shadow-lg p-8 text-center flex-1 opacity-0 translate-y-6 transition-all duration-700 ease-out delay-150 hover:shadow-2xl hover:-translate-y-2" data-animate="">
<div class="w-16 h-16 mx-auto bg-yellow-400 text-blue-900 rounded-full flex items-center justify-center font-bold shadow-md text-xl transition transform group-hover:scale-125 group-hover:rotate-6 animate-bounce-slow">2</div>
<h3 class="mt-6 text-lg font-bold text-blue-700 group-hover:text-yellow-500 transition relative inline-block after:block after:h-0.5 after:bg-yellow-400 after:scale-x-0 group-hover:after:scale-x-100 after:transition after:origin-left">
            Entrance Exam
          </h3>
<p class="text-gray-600 text-sm mt-3 animate-fade-in">Appear for JEE, CAT, MAT, XAT, or NATA.</p>
</div>
<!-- Step 3 -->
<div class="group bg-white rounded-xl shadow-lg p-8 text-center flex-1 opacity-0 translate-y-6 transition-all duration-700 ease-out delay-300 hover:shadow-2xl hover:-translate-y-2" data-animate="">
<div class="w-16 h-16 mx-auto bg-yellow-400 text-blue-900 rounded-full flex items-center justify-center font-bold shadow-md text-xl transition transform group-hover:scale-125 group-hover:rotate-6 animate-bounce-slow">3</div>
<h3 class="mt-6 text-lg font-bold text-blue-700 group-hover:text-yellow-500 transition relative inline-block after:block after:h-0.5 after:bg-yellow-400 after:scale-x-0 group-hover:after:scale-x-100 after:transition after:origin-left">
            Shortlisted
          </h3>
<p class="text-gray-600 text-sm mt-3 animate-fade-in">Candidates shortlisted for interview.</p>
</div>
<!-- Step 4 -->
<div class="group bg-white rounded-xl shadow-lg p-8 text-center flex-1 opacity-0 translate-y-6 transition-all duration-700 ease-out delay-500 hover:shadow-2xl hover:-translate-y-2" data-animate="">
<div class="w-16 h-16 mx-auto bg-yellow-400 text-blue-900 rounded-full flex items-center justify-center font-bold shadow-md text-xl transition transform group-hover:scale-125 group-hover:rotate-6 animate-bounce-slow">4</div>
<h3 class="mt-6 text-lg font-bold text-blue-700 group-hover:text-yellow-500 transition relative inline-block after:block after:h-0.5 after:bg-yellow-400 after:scale-x-0 group-hover:after:scale-x-100 after:transition after:origin-left">
            Personal Interview
          </h3>
<p class="text-gray-600 text-sm mt-3 animate-fade-in">Online or in-person interviews for assessment.</p>
</div>
<!-- Step 5 -->
<div class="group bg-white rounded-xl shadow-lg p-8 text-center flex-1 opacity-0 translate-y-6 transition-all duration-700 ease-out delay-700 hover:shadow-2xl hover:-translate-y-2" data-animate="">
<div class="w-16 h-16 mx-auto bg-yellow-400 text-blue-900 rounded-full flex items-center justify-center font-bold shadow-md text-xl transition transform group-hover:scale-125 group-hover:rotate-6 animate-bounce-slow">5</div>
<h3 class="mt-6 text-lg font-bold text-blue-700 group-hover:text-yellow-500 transition relative inline-block after:block after:h-0.5 after:bg-yellow-400 after:scale-x-0 group-hover:after:scale-x-100 after:transition after:origin-left">
            Offer of Admission
          </h3>
<p class="text-gray-600 text-sm mt-3 animate-fade-in">Final offer communicated via call, email, or post.</p>
</div>
</div>
</div>
</div>
</section>
<!-- CTA Section: Diagonal Parallelogram -->
<section class="section-spacing bg-gradient-to-r from-blue-900 via-blue-800 to-yellow-600 overflow-hidden">
<div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center px-6">
<!-- Left Side (Parallelogram Frame with Student Image) -->
<div class="flex items-center justify-center relative">
<div class="relative w-80 h-96 md:w-96 md:h-[28rem] overflow-hidden group" style="clip-path: polygon(15% 0, 100% 0, 85% 100%, 0% 100%); border: 8px solid #facc15;">
<!-- Glow -->
<div class="absolute inset-0 bg-blue-500 blur-2xl opacity-40 animate-pulse"></div>
<!-- Student Image -->
<img alt="Graphic Era Student" class="w-full h-full object-cover relative z-10 scale-110 transition-transform duration-700 ease-out group-hover:scale-125" decoding="async" loading="lazy" src="../assets/img/main/about-student.webp" style="width:90%"/>
</div>
</div>
<!-- Right Side (CTA Card) -->
<div class="relative">
<div class="backdrop-blur-lg bg-white/90 rounded-2xl shadow-2xl p-8 md:p-10 text-center md:text-left border border-zinc-200">
<!-- Headline -->
<h2 class="text-3xl md:text-4xl font-extrabold text-blue-800 mb-4">
          Unleash Your Potential!
        </h2>
<p class="text-gray-700 mb-6">
          Discover Your Future at Graphic Era (Deemed to be University)<br/>
          Admissions 2025
        </p>
<!-- Highlight Stats -->
<div class="grid grid-cols-3 gap-4 mb-6">
<div class="bg-blue-50 rounded-lg p-3 shadow text-center">
<p class="text-lg font-bold text-blue-700">₹61.99 L</p>
<p class="text-xs">Highest Package</p>
</div>
<div class="bg-blue-50 rounded-lg p-3 shadow text-center">
<p class="text-lg font-bold text-blue-700">Rank 48</p>
<p class="text-xs">NIRF 2025</p>
</div>
<div class="bg-blue-50 rounded-lg p-3 shadow text-center">
<p class="text-lg font-bold text-blue-700">27K+</p>
<p class="text-xs">Alumni Network</p>
</div>
</div>
<!-- CTA Button -->
